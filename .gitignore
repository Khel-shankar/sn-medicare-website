# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# heavy / local-only media (site uses optimized .webp + small mp4s)
public/images/_backup_before_restore/
public/images/_clean_out/
public/images/**/*.bakswap
public/images/**/*.tmp.webp
public/videos/*.mov
local-media/
public/images/*.png
public/images/*.jpeg
public/images/**/*.png
public/images/**/*.jpeg
public/images/**/*.jpg
!public/images/team/
!public/images/team/**

# raw uploads in repo root (not for deploy)
/IMG_*
/*.png
/*.webp
/*.jpeg
/*.jpg
/*.mov
/*.mp4
/WhatsApp*
/kivo-pro-*
